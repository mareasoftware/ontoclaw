---
import Button from '../ui/Button.astro';
import CommandSnippet from '../ui/CommandSnippet.astro';
import { type Lang, translations, defaultLang } from '../../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = translations.cta[lang];
---

<section class="py-20">
  <div class="section-shell">
    <div class="mx-auto max-w-5xl border border-white/10 px-6 py-10 text-center sm:px-10">
      <h2 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4 tracking-[-0.04em]">
        {t.headline}
      </h2>
      <div class="mx-auto mb-8 max-w-3xl">
        <CommandSnippet command={t.command} label="Install OntoMCP" />
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={`/${lang}/getting-started/`} size="lg">
          {t.primaryButton}
        </Button>
        <Button href="/ontostore/" variant="secondary" size="lg">
          {t.secondaryButton}
        </Button>
      </div>
    </div>
  </div>
</section>
